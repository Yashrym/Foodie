# ─────────────────────────────────────────────
# Foodie – Environment Variables Template
# Copy this file to `.env.local` for local dev
# ─────────────────────────────────────────────

# Convex (https://convex.dev) — run `npx convex dev` once to populate
NEXT_PUBLIC_CONVEX_URL=https://YOUR-DEPLOYMENT.convex.cloud
CONVEX_DEPLOYMENT=dev:YOUR-DEPLOYMENT

# NextAuth
AUTH_SECRET=replace-with-a-long-random-string
NEXTAUTH_URL=http://localhost:3000

# Optional OAuth providers (NextAuth)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# OpenAI – Vision + dynamic pricing reasoning
OPENAI_API_KEY=sk-...

# OpenWeather (optional) – used for spoilage prediction context
OPENWEATHER_API_KEY=

# OpenStreetMap tile server – leave default unless self-hosting
NEXT_PUBLIC_OSM_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png
NEXT_PUBLIC_OSM_ATTRIBUTION=&copy; OpenStreetMap contributors

# Default map center (Colombo, LK)
NEXT_PUBLIC_DEFAULT_LAT=6.9271
NEXT_PUBLIC_DEFAULT_LNG=79.8612
NEXT_PUBLIC_DEFAULT_CURRENCY=LKR
