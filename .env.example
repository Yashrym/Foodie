# ─────────────────────────────────────────────
# Foodie – Environment Variables Template
# Copy this file to `.env.local` for local dev.
# For Vercel: paste each non-empty var into the
# Project → Settings → Environment Variables UI.
# ─────────────────────────────────────────────

# ─── Convex (https://convex.dev) ───────────────
# LOCAL DEV (created by `npx convex dev` once):
NEXT_PUBLIC_CONVEX_URL=https://YOUR-DEV-DEPLOYMENT.convex.cloud
CONVEX_DEPLOYMENT=dev:YOUR-DEV-DEPLOYMENT

# VERCEL (production) — get this from the Convex dashboard:
# Convex dashboard → Settings → Deploy Keys → "Generate Production Deploy Key"
# Add it ONLY in Vercel (never commit it):
#   CONVEX_DEPLOY_KEY=prod:YOUR-PROD-DEPLOYMENT|<long secret>
# `convex deploy` will then automatically set NEXT_PUBLIC_CONVEX_URL
# on Vercel at build time, so you do NOT need to set it manually there.

# ─── NextAuth (Auth.js v5) ─────────────────────
# Generate locally: `npx auth secret` or `openssl rand -base64 32`
AUTH_SECRET=replace-with-a-long-random-string
# Local dev only. On Vercel leave AUTH_URL unset — Auth.js auto-detects
# the host because we enabled `trustHost: true` in src/auth.ts.
NEXTAUTH_URL=http://localhost:3000

# Optional OAuth providers (omit to use the demo Credentials flow)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ─── OpenAI – Vision + dynamic pricing ─────────
OPENAI_API_KEY=sk-...

# Optional – weather context for spoilage prediction
OPENWEATHER_API_KEY=

# ─── OpenStreetMap (free, no key needed) ───────
NEXT_PUBLIC_OSM_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png
NEXT_PUBLIC_OSM_ATTRIBUTION=&copy; OpenStreetMap contributors

# Default map center (Colombo, LK)
NEXT_PUBLIC_DEFAULT_LAT=6.9271
NEXT_PUBLIC_DEFAULT_LNG=79.8612
NEXT_PUBLIC_DEFAULT_CURRENCY=LKR
